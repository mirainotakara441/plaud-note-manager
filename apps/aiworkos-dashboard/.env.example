SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Basic認証（両方セットで有効化・未設定なら認証なし）。Vercelにも登録してRedeployで保護ON。
# DASHBOARD_USER=好きなユーザー名
# DASHBOARD_PASS=十分に長いパスワード

# 任意: 連携ダッシュボードにNotionの最新登録状況を表示したい場合のみ設定
# NOTION_TOKEN=secret_xxx
# NOTION_DB_DIARY=一行日記DBのID
# NOTION_DB_LEARNING=学び・ナレッジDBのID
# NOTION_DB_MEETING=会議DBのID
